@hostname = localhost
@port = 8080
@host = http://{{hostname}}:{{port}}
@username = security_demo_user
@email = security_demo_user@example.com
@password = DemoPass123
@newUsername = security_demo_user_v2
@newEmail = security_demo_user_v2@example.com
@token = Ol5Q7UoW02MLrmbXSbQdi7hxgFjRtI7Q6NE58TVVbL1S224RXV-0Ay2D4yIyysRo
@newPassword = DemoPass1234

###### DATOS PARA SELECCIÓN ACADÉMICA ######
@universidadId = 1
@mallaId1 = 1
@mallaId2 = 7
@mallaIdOtraUni = 9

### 1) Registro (201)
POST {{host}}/api/estudiantes/registro
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}",
  "email": "{{email}}"
}

### 2) Registro repetido (409)
POST {{host}}/api/estudiantes/registro
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}",
  "email": "{{email}}"
}

### 3) Login OK (200) - Copia token del response
POST {{host}}/api/login
Content-Type: application/json

{
  "identifier": "{{username}}",
  "password": "{{password}}"
}

### 4) Login con password invalido (401)
POST {{host}}/api/login
Content-Type: application/json

{
  "identifier": "{{username}}",
  "password": "wrong_password"
}

### 5) Obtener perfil por username (200)
GET {{host}}/api/estudiantes/perfil/{{username}}
Authorization: Bearer {{token}}

### 6) Editar perfil (200)
PUT {{host}}/api/estudiantes/perfil/{{username}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nombre": "Security",
  "apellido": "Demo",
  "universidad": "Universidad Catolica Boliviana San Pablo",
  "carrera": "Ingenieria de Sistemas",
  "carnetIdentidad": "CI-900001",
  "fechaNacimiento": "2000-01-15",
  "email": "{{newEmail}}",
  "username": "{{newUsername}}"
}

### 7) Verificar perfil actualizado (200)
GET {{host}}/api/estudiantes/perfil/{{newUsername}}
Authorization: Bearer {{token}}

### 8) Cambiar contrasenia (200)
POST {{host}}/api/change-password
Authorization: Bearer {{token}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "currentPassword": "{{password}}",
  "newPassword": "{{newPassword}}",
  "confirmNewPassword": "{{newPassword}}"
}

### 9) Obtener selección académica actual (200) - Será null si no se ha hecho selección
GET {{host}}/api/academico/seleccion
Authorization: Bearer {{token}}

### 10) Guardar selección académica inicial (200)
### Universidad Privada Boliviana + Ingenieria Financiera Malla 2024
PUT {{host}}/api/academico/seleccion
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "universidadId": {{universidadId}},
  "carreraId": null,
  "mallaId": {{mallaId1}}
}

### 11) Cambiar a otra malla de la misma universidad (200)
### Esperado: semestre_actual se reinicia a 1
### De Malla 2024 a Malla 2025 (Ingenieria de Sistemas)
PUT {{host}}/api/academico/seleccion
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "universidadId": {{universidadId}},
  "carreraId": null,
  "mallaId": {{mallaId2}}
}

### 12) Intentar guardar malla de OTRA universidad (400)
### Error esperado: "La malla no pertenece a la universidad seleccionada"
### Malla 9 es de Universidad Catolica Boliviana (id=2)
PUT {{host}}/api/academico/seleccion
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "universidadId": {{universidadId}},
  "carreraId": null,
  "mallaId": {{mallaIdOtraUni}}
}


